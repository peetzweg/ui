# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# vite build output
/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# typescript
*.tsbuildinfo

# Prototype archives + working copies (kept local, not committed)
/prototypes/*.zip
/prototypes/_extracted/

# Vocs route typegen (auto-generated)
/src/pages.gen.ts

# Claude Code session state
/.claude/

# Scratch media files
*.mp4
